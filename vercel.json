{
  "buildCommand": "cd frontend && npm install && npm run build",
  "outputDirectory": "dist",
  "installCommand": "cd frontend && npm install",
  "framework": null,
  "rewrites": [
    { "source": "/predictions/:path*", "destination": "/predictions/:path*" },
    { "source": "/fixtures/:path*",    "destination": "/fixtures/:path*" },
    { "source": "/matches/:path*",     "destination": "/matches/:path*" },
    { "source": "/teams/:path*",       "destination": "/teams/:path*" },
    { "source": "/leagues/:path*",     "destination": "/leagues/:path*" },
    { "source": "/accuracy/:path*",    "destination": "/accuracy/:path*" },
    { "source": "/models/:path*",      "destination": "/models/:path*" },
    { "source": "/h2h/:path*",         "destination": "/h2h/:path*" },
    { "source": "/referees/:path*",    "destination": "/referees/:path*" },
    { "source": "/(.*)",               "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/predictions/latest.json",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=900, stale-while-revalidate=1800" }]
    },
    {
      "source": "/predictions/:date.json",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=3600, stale-while-revalidate=86400" }]
    },
    {
      "source": "/accuracy/results.json",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=1800" }]
    },
    {
      "source": "/:path*.json",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=3600" }]
    }
  ]
}
